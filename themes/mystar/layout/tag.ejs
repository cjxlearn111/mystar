<section class="archive-shell container-reading">
  <header class="page-header">
    <p class="section-label">Tag</p>
    <h1 class="page-title"><%= page.tag ? page.tag : '标签' %></h1>
  </header>

  <div class="post-list">
    <% page.posts.each(function(post){ %>
      <%- partial('partial/post-card', { post: post }) %>
    <% }) %>
  </div>
</section>

