<header class="site-header">
  <div class="container-shell header-inner">
    <a class="brandmark" href="/"><%= theme.brand.name %></a>
    <div class="brand-issue"><%= theme.brand.issue %></div>
    <nav class="site-nav">
      <% for (const [label, path] of Object.entries(theme.menu)) { %>
        <a href="<%= url_for(path) %>"><%= label %></a>
      <% } %>
    </nav>
  </div>
</header>

